{
  "version": 2,
  "installCommand": "npm install",
  "builds": [
    {
      "src": "api/contact.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/orders.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/create-payment-intent.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/paypal/create-order.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/paypal/capture-order.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/api/contact$",
      "dest": "/api/contact.js"
    },
    {
      "src": "^/api/orders$",
      "dest": "/api/orders.js"
    },
    {
      "src": "^/api/create-payment-intent$",
      "dest": "/api/create-payment-intent.js"
    },
    {
      "src": "^/api/paypal/create-order$",
      "dest": "/api/paypal/create-order.js"
    },
    {
      "src": "^/api/paypal/capture-order$",
      "dest": "/api/paypal/capture-order.js"
    }
  ]
}
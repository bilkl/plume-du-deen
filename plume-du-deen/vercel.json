{
  "installCommand": "npm install",
}
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "^/favicon.ico$",
      "dest": "/client/dist/favicon.ico"
    },
    {
      "src": "^/$",
      "dest": "/client/dist/index.html"
    },
    {
      "src": "^/(.*)$",
      "dest": "/client/dist/$1"
    }
  ]
}
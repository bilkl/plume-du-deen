# Example environment variables for local development
# Copy this file to `.env` and replace the placeholders with real values.

# Resend API key (obligatoire pour l'envoi d'emails)
RESEND_API_KEY=your_resend_api_key_here

# Adresse email d'administration qui recevra les messages de contact
ADMIN_EMAIL=contact@plume-du-deen.com

# Optionnel: adresse expéditrice pour les emails
FROM_EMAIL=Plume du Deen <contact@plume-du-deen.com>

# URL(s) autorisée(s) pour le CORS côté API (Vercel).
# Pour GitHub Pages, mettez l'origine (sans chemin) ex:
# FRONTEND_URL=https://<user>.github.io
# Vous pouvez fournir plusieurs origines séparées par des virgules.
FRONTEND_URL=http://localhost:3000

# Base URL du backend API utilisé par le frontend en production (GitHub Pages -> Vercel).
# En local, laissez vide pour utiliser le proxy Vite (same-origin /api -> localhost:3001).
VITE_API_BASE_URL=

# Optionnel (backend): base URL de l'API pour les appels internes (ex: PayPal capture -> /api/orders).
# Si non défini, l'API utilise automatiquement l'hôte de la requête.
API_BASE_URL=

# Stripe (paiement par carte)
# Publishable key côté frontend (commence par pk_test_ / pk_live_)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# Secret key côté backend (commence par sk_test_ / sk_live_)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
